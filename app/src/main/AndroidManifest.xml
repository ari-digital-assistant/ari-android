<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <!--
      Needed so TimerAlertService (foregroundServiceType=mediaPlayback) can
      promote itself to foreground on API 34+. The app plays a looping
      alert sound + TTS when a timer fires; mediaPlayback is the honest
      category for that.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <!--
      Needed so BootReceiver can fire after the user reboots and opt-in
      start-on-boot is enabled. Off by default — only matters when the user
      flips the Settings toggle.
    -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!--
      Timer expiry uses AlarmManager.setExactAndAllowWhileIdle. Two permissions
      cover the same capability across API levels:
        - USE_EXACT_ALARM is the Play-Store-preferred path on API 33+: a
          normal permission, auto-granted at install, allowlisted for timer
          and reminder apps. No runtime prompt.
        - SCHEDULE_EXACT_ALARM is kept for API 31-32 where USE_EXACT_ALARM
          isn't defined. `canScheduleExactAlarms()` returns true whenever
          either is in effect.
    -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!--
      SYSTEM_ALERT_WINDOW is held SOLELY to obtain Background Activity Launch
      privilege so WakeWordService can start VoiceOverlayActivity over the
      keyguard on every wake-word detection (not just the first one within the
      FGS BAL grace window). Ari does NOT draw any TYPE_APPLICATION_OVERLAY
      windows. Same pattern as Signal/Telegram/WhatsApp incoming-call screens.
    -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!--
      Calendar access — needed by the reminder skill's Calendar / Both
      destination modes for enumerating the user's calendars
      (CalendarContract.Calendars) and inserting VEVENT rows
      (CalendarContract.Events). Both are runtime-granted dangerous
      permissions; the skill settings panel triggers the request when
      the user picks a Calendar destination or opens the calendar
      picker, never at app launch.
    -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" />

    <!--
      OpenTasks-compatible task provider access — needed by the
      reminder skill's Tasks / Both destination modes. Unfortunately
      there's no single universal authority: OpenTasks-the-original
      registers `org.dmfs.tasks` with `org.dmfs.permission.*`, Tasks.org
      forks the same provider class under `org.tasks.opentasks` with
      its own `org.tasks.permission.*` namespace, and other compatible
      apps pick their own conventions again. We declare both
      permission sets up front so the runtime grant works regardless
      of which provider the user's chosen app exposes — Android
      silently drops permissions whose target isn't installed.
    -->
    <uses-permission android:name="org.dmfs.permission.READ_TASKS" />
    <uses-permission android:name="org.dmfs.permission.WRITE_TASKS" />
    <uses-permission android:name="org.tasks.permission.READ_TASKS" />
    <uses-permission android:name="org.tasks.permission.WRITE_TASKS" />

    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
        <intent>
            <action android:name="android.intent.action.WEB_SEARCH" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        <!--
          Package visibility (API 30+) — without this we can't even
          probe the OpenTasks-compatible ContentProvider authorities to
          see if any provider app is installed. Each compatible app
          picks its own authority name, so we list every one we know
          about up front. TasksProvider tries each in turn and uses
          whichever the package manager reports as installed.
        -->
        <provider android:authorities="org.dmfs.tasks" />
        <provider android:authorities="org.tasks.opentasks" />
    </queries>

    <application
        android:name=".AriApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Ari">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Ari"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.ASSIST" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".wakeword.StartListeningActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <activity
            android:name=".wakeword.WakeTrampolineActivity"
            android:exported="false"
            android:taskAffinity="dev.heyari.ari.wake"
            android:launchMode="singleInstance"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <activity
            android:name=".voice.VoiceOverlayActivity"
            android:exported="false"
            android:taskAffinity="dev.heyari.ari.voice"
            android:launchMode="singleInstance"
            android:excludeFromRecents="true"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <service
            android:name=".wakeword.WakeWordService"
            android:foregroundServiceType="microphone"
            android:exported="false" />

        <!--
          Plays the Siri-style alert loop (sound + spoken name on repeat)
          when a card's countdown fires. Audio must survive backgrounding
          and screen-off, so the service promotes itself with
          FOREGROUND_SERVICE_TYPE_MEDIA_PLAYBACK.
        -->
        <service
            android:name=".notifications.AlertService"
            android:foregroundServiceType="mediaPlayback"
            android:exported="false" />

        <!--
          Full-takeover lock-screen UI for skill-emitted alerts with
          full_takeover && urgency == critical. Launched via the
          notification's full-screen intent. Single-instance + own task
          affinity so it never competes with MainActivity.
        -->
        <activity
            android:name=".notifications.AlertActivity"
            android:exported="false"
            android:launchMode="singleInstance"
            android:taskAffinity="dev.heyari.ari.alert"
            android:excludeFromRecents="true"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:theme="@style/Theme.Ari" />

        <receiver
            android:name=".wakeword.BootReceiver"
            android:exported="true"
            android:directBootAware="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!--
          Card expiry: AlarmManager fires this when a card's
          countdown_to_ts_ms is reached. The receiver kicks AlertService
          (if the card declared an on_complete.alert) and removes the
          card from the repo (if dismiss_card was true).
        -->
        <receiver
            android:name=".actions.CardExpiryReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="dev.heyari.ari.CARD_EXPIRY_FIRE" />
            </intent-filter>
        </receiver>

        <!--
          Generic notification-action router: any tap on a notification
          action button (other than the reserved local-only ids) routes
          here, which then sends the action's `utterance` through
          engine.processInput.
        -->
        <receiver
            android:name=".actions.NotificationActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="dev.heyari.ari.NOTIFICATION_ACTION" />
            </intent-filter>
        </receiver>

        <!-- Digital assistant role services -->
        <service
            android:name=".assistant.AriVoiceInteractionService"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_VOICE_INTERACTION"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.voice.VoiceInteractionService" />
            </intent-filter>
            <meta-data
                android:name="android.voice_interaction"
                android:resource="@xml/voice_interaction_service" />
        </service>

        <service
            android:name=".assistant.AriVoiceInteractionSessionService"
            android:permission="android.permission.BIND_VOICE_INTERACTION"
            android:exported="false" />

        <!--
          Disable the default WorkManagerInitializer so AriApplication's
          Configuration.Provider path (Hilt-provided WorkerFactory) is the
          one WorkManager uses. Required for @HiltWorker to get its
          dependencies injected.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <service
            android:name=".assistant.AriRecognitionService"
            android:exported="true">
            <intent-filter>
                <action android:name="android.speech.RecognitionService" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <meta-data
                android:name="android.speech"
                android:resource="@xml/recognition_service" />
        </service>
    </application>

</manifest>
